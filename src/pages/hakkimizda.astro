---
export const prerender = true; 
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets'; // 🚀 Astro Image Eklendi

// 🚀 Resimleri projeden dahil ediyoruz (Otomatik optimize olacaklar)
import hakkimizdaResmi from '../assets/images/hakkimizda-sondaj.webp';
import bannerResmi from '../assets/images/hizmetler/su-kuyusu-sondaji.webp';

const pageTitle = "Hakkımızda";
const pageDescription = "2002'den beri İstanbul ve çevre illerde su sondajı, dalgıç pompa ve zemin etüdü hizmetleri sunan çözüm ortağınız.";
---

<Layout title={pageTitle} description={pageDescription}>
  
  <div class="page-header">
    <div class="container">
      <h1>Hakkımızda</h1>
      <p>Tecrübe, Mühendislik ve Teknolojinin Buluştuğu Nokta</p>
    </div>
  </div>

  <div class="main-content container">
    
    <div class="about-section">
      <div class="about-image-wrapper">
        <div class="experience-badge">20+ Yıllık Tecrübe</div>
        <!-- 🚀 Optimize Edilmiş Hakkımızda Resmi (Eager ile hızlı yüklenir) -->
        <Image 
          src={hakkimizdaResmi} 
          alt="Ünlütürk Sondaj Ekibi ve Makine Parkuru" 
          class="about-image" 
          width={600} 
          height={400} 
          fetchpriority="high"
          loading="eager"
          decoding="sync"
        />
      </div>

      <div class="about-text">
        <h2 class="section-title">Biz Kimiz?</h2>
        <p>
          **Ünlütürk Sondaj**, 2002 yılında İstanbul'da, yeraltı kaynaklarını en verimli şekilde yeryüzüne çıkarmak ve yönetmek amacıyla kurulmuştur. Sektöre küçük bir sondaj makinesiyle başlayan serüvenimiz, bugün geniş makine parkuru, uzman mühendis kadrosu ve yüzlerce başarılı referans ile devam etmektedir.
        </p>
        <p>
          Sadece "kuyu açıp giden" bir firma değiliz. Biz, suyun jeofizik etüdünden başlayarak; sondajı, borulaması, pompa seçimi ve DSİ ruhsatlandırma süreçlerine kadar **anahtar teslim proje** üreten bir mühendislik firmasıyız.
        </p>
        
        <div class="features-grid">
          <div class="feature-item">
            <span class="check-icon">✓</span> Garantili Sondaj
          </div>
          <div class="feature-item">
            <span class="check-icon">✓</span> DSİ Ruhsat Takibi
          </div>
          <div class="feature-item">
            <span class="check-icon">✓</span> 7/24 Teknik Servis
          </div>
          <div class="feature-item">
            <span class="check-icon">✓</span> Ücretsiz Keşif
          </div>
        </div>
      </div>
    </div>

    <div class="mv-section">
      <div class="mv-card mission">
        <h3>Misyonumuz</h3>
        <p>Müşterilerimize en doğru teknikle, sürdürülebilir ve kesintisiz su kaynağı sağlamak. Teknolojik gelişmeleri takip ederek, sondaj maliyetlerini düşürürken kuyu ömrünü ve su kalitesini maksimum seviyeye çıkarmak.</p>
      </div>
      <div class="mv-card vision">
        <h3>Vizyonumuz</h3>
        <p>Marmara Bölgesi'nin en güvenilir ve donanımlı sondaj firması olmak. "Ünlütürk yaptıysa sağlamdır" algısını koruyarak, sektörde kalite ve güvenliğin standartlarını belirlemek.</p>
      </div>
    </div>

    <div class="why-us">
      <h2 class="text-center">Neden Bizi Tercih Etmelisiniz?</h2>
      <div class="why-grid">
        <div class="why-box">
          <div class="icon">🚜</div>
          <h4>Güçlü Makine Parkuru</h4>
          <p>Hem yumuşak zeminler (Rotary) hem de sert kayalar (Havalı) için son teknoloji makinelerimizle her türlü arazide çalışıyoruz.</p>
        </div>
        <div class="why-box">
          <div class="icon">👷‍♂️</div>
          <h4>Mühendislik Yaklaşımı</h4>
          <p>Ezbere iş yapmıyoruz. Jeofizik mühendislerimizle zemin etüdü yapıyor, "su çıkmaz" dediğimiz yerde sizi boşuna masrafa sokmuyoruz.</p>
        </div>
        <div class="why-box">
          <div class="icon">📜</div>
          <h4>Resmi & Ruhsatlı</h4>
          <p>Kaçak kuyu riskine girmeyin. Tüm DSİ Arama ve Kullanma ruhsat süreçlerinizi uzman ekibimizle A'dan Z'ye takip ediyoruz.</p>
        </div>
      </div>
    </div>

  </div>
</Layout>

<style define:vars={{ bgImage: `url('${bannerResmi.src}')` }}>
  /* GENEL AYARLAR */
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }
  
  /* 🚀 ÜST BANNER (Astro Optimizasyonlu Arka Plan) */
  .page-header {
    background: linear-gradient(rgba(0,51,102,0.9), rgba(0,51,102,0.8)), var(--bgImage); 
    background-size: cover;
    background-position: center;
    color: white;
    text-align: center;
    padding: 60px 0;
    margin-bottom: 50px;
  }
  .page-header h1 {
    font-size: 2.5rem;
    font-weight: bold;
    margin-bottom: 10px;
  }
  .page-header p {
    font-size: 1.2rem;
    opacity: 0.9;
  }

  /* BİZ KİMİZ BÖLÜMÜ */
  .about-section {
    display: flex;
    flex-wrap: wrap;
    gap: 50px;
    align-items: center;
    margin-bottom: 80px;
  }
  .about-image-wrapper {
    flex: 1;
    min-width: 300px;
    position: relative;
  }
  .about-image {
    width: 100%;
    height: auto;
    aspect-ratio: 4/3;
    object-fit: cover;
    border-radius: 15px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.15);
    border: 5px solid white;
  }
  .experience-badge {
    position: absolute;
    top: 20px;
    left: -10px;
    background: #C25900; /* Kontrast uyumlu turuncu */
    color: white;
    padding: 10px 20px;
    font-weight: bold;
    border-radius: 30px;
    box-shadow: 0 5px 15px rgba(194, 89, 0, 0.4);
    z-index: 10;
  }
  .about-text {
    flex: 1.2;
    min-width: 300px;
  }
  .section-title {
    color: #003366;
    font-size: 2rem;
    margin-bottom: 20px;
    border-bottom: 3px solid #C25900;
    display: inline-block;
    padding-bottom: 5px;
  }
  .about-text p {
    color: #444;
    line-height: 1.6;
    margin-bottom: 15px;
    font-size: 1.05rem;
  }

  /* ÖZELLİK LİSTESİ */
  .features-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 15px;
    margin-top: 20px;
  }
  .feature-item {
    font-weight: 600;
    color: #003366;
    display: flex;
    align-items: center;
  }
  .check-icon {
    color: #C25900;
    margin-right: 10px;
    font-weight: bold;
  }

  /* MİSYON VİZYON */
  .mv-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
    margin-bottom: 80px;
  }
  .mv-card {
    padding: 30px;
    border-radius: 10px;
    border-left: 5px solid;
  }
  .mv-card.mission {
    background-color: #f0f7ff;
    border-color: #003366;
  }
  .mv-card.vision {
    background-color: #fff5eb;
    border-color: #C25900;
  }
  .mv-card h3 {
    font-size: 1.5rem;
    margin-bottom: 15px;
    font-weight: bold;
  }
  .mission h3 { color: #003366; }
  .vision h3 { color: #C25900; }

  /* NEDEN BİZ */
  .why-us {
    background-color: #f9f9f9;
    padding: 60px 20px;
    border-radius: 20px;
    margin-bottom: 60px;
  }
  .why-us h2 {
    color: #003366;
    font-size: 2rem;
    margin-bottom: 40px;
    text-align: center;
  }
  .why-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 30px;
  }
  .why-box {
    background: white;
    padding: 30px;
    border-radius: 10px;
    text-align: center;
    box-shadow: 0 5px 20px rgba(0,0,0,0.05);
    transition: transform 0.3s;
  }
  .why-box:hover {
    transform: translateY(-5px);
  }
  .why-box .icon {
    font-size: 3rem;
    margin-bottom: 15px;
  }
  .why-box h4 {
    color: #003366;
    font-size: 1.3rem;
    margin-bottom: 15px;
    font-weight: bold;
  }
  .why-box p {
    color: #666;
    font-size: 0.95rem;
  }

  /* MOBİL AYARLAR */
  @media (max-width: 768px) {
    .mv-section {
      grid-template-columns: 1fr;
    }
    .page-header h1 {
      font-size: 1.8rem;
    }
  }
</style>