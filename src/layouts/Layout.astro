---
import { getEntry, getCollection } from 'astro:content'; 
import SpeedInsights from "@vercel/speed-insights/astro";
import { ViewTransitions } from 'astro:transitions';
import { Image } from 'astro:assets';
import siteLogo from '../assets/images/logo-unlutur-sondaj.webp'; // Logonun yeni yolu

// Props: Sayfadan gelen özel başlık ve açıklama
const { 
    title, 
    description,
    image, // Blog yazısı resmi varsa
    articleDate, // Blog tarihi varsa
    type = "website" // website veya article
} = Astro.props;

// Ayarları Çek
const genelAyarlar = await getEntry('ayarlar', 'genel');
const veri = genelAyarlar ? genelAyarlar.data : {
    telefon: "0532 540 68 29",
    email: "info@safadalgicpompa.com",
    adres: "Adres Belirtilmedi",
    slogan: "Safa Dalgıç Pompa",
    logo: "/images/genel/logo-unluturksondaj.png", 
    favicon: "/favicon.svg",
    seoDescription: "Sondaj ve Dalgıç Pompa Hizmetleri"
};

const tumHizmetler = await getCollection('hizmetler');
tumHizmetler.sort((a, b) => a.data.order - b.data.order);

const sayfaBasligi = title ? `${title} | ${veri.siteBaslik || 'Ünlütürk Sondaj'}` : (veri.siteBaslik || 'Ünlütürk Sondaj');
const sayfaAciklamasi = description || veri.seoDescription;

const siteUrl = Astro.site ? Astro.site.href : "https://unluturksondaj.com";
const canonicalURL = new URL(Astro.url.pathname, siteUrl);

const hamResim = image || veri.logo;
const shareImage = hamResim.startsWith('http') 
    ? hamResim 
    : new URL(hamResim, siteUrl).href;

const schemaData = {
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  "name": veri.siteBaslik || "Safa Dalgıç Pompa",
  "image": shareImage,
  "description": veri.seoDescription,
  "telephone": veri.telefon,
  "email": veri.email,
  "url": siteUrl,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": veri.adres,
    "addressLocality": "İstanbul",
    "addressCountry": "TR",
    "postalCode": "34912" 
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "40.9281093",  
    "longitude": "29.3093346" 
  },
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
    "opens": "00:00",
    "closes": "23:59"
  },
  "priceRange": "₺₺"
};
---

<!DOCTYPE html>
<html lang="tr">
<head>
<script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
})(window,document,'script','dataLayer','GTM-NKZ8CXP9');</script>
<meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" href={veri.favicon} />
    <title>{sayfaBasligi}</title>
    <meta name="description" content={sayfaAciklamasi}>
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content="index, follow" />
    {articleDate && (
        <meta property="article:published_time" content={new Date(articleDate).toISOString()} />
    )}
    <meta property="og:title" content={sayfaBasligi} />
    <meta property="og:description" content={sayfaAciklamasi} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content={type} />
    <meta property="og:image" content={shareImage} />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    
    <link rel="stylesheet" href="/css/style.css">
    
    <link rel="preload" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"></noscript>

    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&family=Open+Sans:wght@400;600&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800&family=Open+Sans:wght@400;600&display=swap"></noscript>
    
    <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
    
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-LWL807NJ5B"></script>
    <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-LWL807NJ5B');
    </script>
    
    <ViewTransitions />
</head>
<body>
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-NKZ8CXP9"
height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
<div class="top-bar">
        <div class="container">
            <div class="top-slogan">
                <i class="fas fa-tools"></i> {veri.slogan}
            </div>
            <div class="contact-info">
                <a href={`tel:${veri.telefon}`}><i class="fas fa-phone"></i> {veri.telefon}</a>
                <a href={`mailto:${veri.email}`}><i class="fas fa-envelope"></i> {veri.email}</a>
            </div>
        </div>
    </div>

    <header id="header">
        <div class="container">
            <div class="logo">
                <a href="/">
                    <!-- 🚀 RETİNA EKRAN DÜZELTMESİ: Width 500 yapıldı, CSS ile 250px'e sıkıştırıldı -->
                    <Image 
                      src={siteLogo} 
                      alt={veri.siteBaslik || "Ünlütürk Sondaj"} 
                      width={500} 
                      fetchpriority="high"
                      loading="eager"
                      decoding="sync"
                      style="width: 250px; max-width: 100%; height: auto;"
                    />           
                </a>
            </div>
            
            <nav>
                <div class="menu-icon" id="menuToggle"><i class="fas fa-bars"></i></div>
                <ul id="menuList">
                    <li class="mobile-menu-header">
                        <!-- 🚀 RETİNA EKRAN DÜZELTMESİ: Width 300 yapıldı, CSS ile 150px'e sıkıştırıldı -->
                        <Image 
                            src={siteLogo} 
                            alt={veri.siteBaslik || "Ünlütürk Sondaj Logo"} 
                            width={300} 
                            style="width: 150px; max-width: 100%; height: auto;" 
                          />
                        <i class="fas fa-times" id="menuClose"></i>
                    </li>
                    <li><a href="/">Anasayfa</a></li>
                    <li><a href="/hakkimizda">Hakkımızda</a></li>
                    
                    <li class="dropdown">
                        <a href="/hizmetler" class="dropbtn" id="servicesLink">
                            Hizmetlerimiz <i class="fas fa-chevron-down"></i>
                        </a>
                        <ul class="dropdown-content">
                            {tumHizmetler.map((hizmet) => (
                                <li>
                                    <a href={`/hizmetler/${hizmet.slug}`}>{hizmet.data.title}</a>
                                </li>
                            ))}
                        </ul>
                    </li>
                    <li><a href="/#referanslar">Yorumlar</a></li>
                    <li><a href="/blog">Blog</a></li>
                    <li><a href="/iletisim">İletişim</a></li>
                    <li class="nav-btn-item"><a href="/iletisim" class="btn-nav-cta">TEKLİF AL</a></li>
                </ul>
                <div class="menu-overlay" id="menuOverlay"></div>
            </nav>
        </div>
    </header>

    <slot />

    <footer id="footer">
        <div class="container">
            <div class="footer-grid">
                <div class="footer-col">
                    <h3>Hakkımızda</h3>
                    <!-- 🚀 RETİNA EKRAN DÜZELTMESİ: Width 400 yapıldı, CSS ile 200px'e sıkıştırıldı -->
                    <Image 
                        src={siteLogo} 
                        alt={veri.siteBaslik || "Ünlütürk Sondaj Kurumsal"} 
                        width={400}
                        loading="lazy" 
                        class="footer-logo" 
                        style="background:white; padding:5px; border-radius:4px; width: 200px; max-width: 100%; height: auto;" 
                      />
                    <p>"Firmamız Marmara bölgesi genelinde sondaj, sondaj etüdü, dalgıç pompa satış ve servis hizmetleri vermekteyiz."</p>
                </div>
                <div class="footer-col">
                    <h3>Hızlı Menü</h3>
                    <ul>
                        <li><a href="/">Anasayfa</a></li>
                        <li><a href="/#hizmetler">Hizmetlerimiz</a></li>
                        <li><a href="/hakkimizda">Hakkımızda</a></li>
                        <li><a href="/iletisim">İletişim</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h3>İletişim</h3>
                    <p><strong>Adres:</strong> {veri.adres}</p>
                    <p><strong>Tel:</strong> <a href={`tel:${veri.telefon}`}>{veri.telefon}</a></p>
                    <p><strong>Email:</strong> {veri.email}</p>
                </div>
                <div class="footer-col gallery-preview">
                    <h3>Galeri</h3>
                    <div class="mini-gallery">
                        <img src="/images/genel/anasayfa1.webp" alt="Galeri 1" loading="lazy">
                        <img src="/images/genel/anasayfa2.webp" alt="Galeri 2" loading="lazy">
                    </div>
                </div>
            </div>
            <div class="footer-bottom">
                <p>© 2026 Ünlü Türk Sondaj. Tüm Hakları Saklıdır.</p>
            </div>
        </div>
    </footer>

    <script src="/js/script.js" is:inline></script>
    
    <div class="mobile-contact-bar">
      <a href="tel:+905325406829" class="contact-btn btn-call">
        <i class="fas fa-phone-alt"></i>
        <span>Hemen Ara</span>
      </a>

      <a href="https://wa.me/905325406829?text=Merhaba,%20sondaj%20hizmetleri%20hakkında%20bilgi%20almak%20istiyorum." target="_blank" class="contact-btn btn-whatsapp">
        <i class="fab fa-whatsapp"></i>
        <span>WhatsApp'tan Yaz</span>
      </a>
    </div>

<style>
  .mobile-contact-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 60px;
    background: #fff;
    display: flex;
    z-index: 9999; 
    box-shadow: 0 -2px 15px rgba(0,0,0,0.1); 
    font-family: system-ui, -apple-system, sans-serif;
  }
  .contact-btn {
    flex: 1; 
    display: flex;
    justify-content: center;
    align-items: center;
    text-decoration: none;
    color: white;
    font-size: 16px;
    font-weight: 600;
    gap: 10px; 
    transition: background 0.3s;
  }

  /* 🚀 ERİŞİLEBİLİRLİK KONTRAST DÜZELTMELERİ */
  .btn-call { background-color: #004494; }
  .btn-call:hover { background-color: #003370; }
  
  /* WhatsApp rengi kontrast testinden geçecek şekilde doygun yeşile çekildi */
  .btn-whatsapp { background-color: #10752b !important; color: #ffffff !important; }
  .btn-whatsapp:hover { background-color: #0c5c21 !important; }
  
  /* Teklif Al butonu kontrastı geçmesi için tok turuncu yapıldı */
  .btn-nav-cta {
      background-color: #C25900 !important;
      color: #ffffff !important;
  }
  .btn-nav-cta:hover {
      background-color: #994600 !important;
  }
  /* ------------------------------------------------ */

  .contact-btn i { font-size: 20px; }

  @media (min-width: 769px) {
    .mobile-contact-bar {
      width: auto; left: auto; right: 20px; bottom: 20px;     
      background: transparent; box-shadow: none;
      flex-direction: column; gap: 10px; height: auto;
    }
    .contact-btn {
      font-size: 14px; width: 200px; border-radius: 50px; 
      padding: 12px 20px; box-shadow: 0 4px 10px rgba(0,0,0,0.2);
    }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const phoneInput = document.getElementById('phoneInput');
    if (phoneInput) {
      phoneInput.addEventListener('input', function(e) {
        let value = this.value.replace(/[^0-9]/g, '');
        if (value.length > 11) value = value.slice(0, 11);
        this.value = value;
      });
    }

    const form = document.getElementById('anasayfa-formu');
    const messageDiv = document.getElementById('form-message');
    const submitBtn = document.getElementById('submit-btn');

    if (form) {
      form.onsubmit = function(e) {
        e.preventDefault();
        const originalText = submitBtn.innerText;
        submitBtn.innerText = 'GÖNDERİLİYOR...';
        submitBtn.disabled = true;
        submitBtn.style.opacity = '0.7';

        const formData = new FormData(form);

        fetch(form.action, {
          method: 'POST',
          body: formData,
          headers: { 'Accept': 'application/json' }
        })
        .then(response => {
          if (response.ok) {
            messageDiv.style.display = 'block';
            messageDiv.style.backgroundColor = '#d4edda';
            messageDiv.style.color = '#155724';
            messageDiv.innerText = '✅ Mesajınız başarıyla gönderildi! Teşekkürler.';
            form.reset(); 
          } else throw new Error('Form gönderilemedi');
        })
        .catch(error => {
          messageDiv.style.display = 'block';
          messageDiv.style.backgroundColor = '#f8d7da';
          messageDiv.style.color = '#721c24';
          messageDiv.innerText = '❌ Bir hata oluştu. Lütfen daha sonra tekrar deneyin.';
        })
        .finally(() => {
          submitBtn.innerText = originalText;
          submitBtn.disabled = false;
          submitBtn.style.opacity = '1';
          setTimeout(() => { messageDiv.style.display = 'none'; }, 5000);
        });
      };
    }
  });
</script>

<SpeedInsights />
</body>
</html>